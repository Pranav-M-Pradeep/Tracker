# ──────────────────────────────────────────
# DATABASE (PostgreSQL — e.g. Neon or Supabase)
# ──────────────────────────────────────────
# Prisma uses DATABASE_URL for queries (pooled connection for serverless)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# DIRECT_URL is used for migrations (non-pooled)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# ──────────────────────────────────────────
# NEXTAUTH
# ──────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-32-char-secret-here"

# Your deployed URL (on Vercel, set to https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
