# ──────────────────────────────────────────
# DATABASE — MongoDB Atlas
# ──────────────────────────────────────────
# Get this from: MongoDB Atlas → Connect → Drivers
# Replace <username>, <password>, and <cluster> with your actual values
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/tracker?retryWrites=true&w=majority&appName=Cluster0"

# ──────────────────────────────────────────
# NEXTAUTH
# ──────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-32-char-secret-here"

# Your deployed URL (on Vercel, set to https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
